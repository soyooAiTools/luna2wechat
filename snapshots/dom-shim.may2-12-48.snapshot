549	  // ---------- document ----------
550	  if (!g.document) {
551	    const eventBus = makeEmitter();
552	    const elements = new Map();
553	    elements.set('application-canvas', g.canvas);
554	
555	    // playable-libs 在 wx.onShow/onHide "manually adapt" 路径会给 documentElement / body / canvas 绑监听器，
556	    // 都得有 addEventListener；用同一个 eventBus 让事件互通，避免出现"绑了但永不触发"的死表面。
557	    const docElEvents = makeEmitter();
558	    const bodyEvents = makeEmitter();
559	    const headEvents = makeEmitter();
560	    const canvasEvents = makeEmitter();
561	    const evApi = (bus) => ({
562	      addEventListener: (t, cb) => bus.on(t, cb),
563	      removeEventListener: (t, cb) => bus.off(t, cb),
564	      dispatchEvent: (ev) => { bus.emit(ev && ev.type, ev); return true; },
565	    });
566	
567	    g.document = {
568	      readyState: 'loading',
569	      // PlayCanvas Application 启动期会查这俩判断窗口可见性 (页面 visibility / 焦点)
570	      hasFocus: () => true,
571	      hidden: false,
572	      visibilityState: 'visible',
573	      title: '',
574	      documentElement: Object.assign({ style: {}, _bus: docElEvents }, evApi(docElEvents)),
575	      body: Object.assign({ style: {}, appendChild() {}, removeChild() {}, _bus: bodyEvents }, evApi(bodyEvents)),
576	      head: Object.assign({ appendChild() {}, removeChild() {}, _bus: headEvents }, evApi(headEvents)),
577	
578	      getElementById(id) {
