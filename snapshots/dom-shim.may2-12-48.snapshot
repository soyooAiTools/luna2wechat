431	      ready(cb) { try { cb && cb(); } catch (e) { console.error('[Bridge.ready] cb threw', e); } },
432	      // 占位：playable-libs 可能再调 .send / .register 之类，全部 noop 不爆
433	      send() {}, register() {}, on() {}, off() {}, emit() {},
