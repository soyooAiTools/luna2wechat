1	/**
2	 * Minimum DOM shim for Luna runtime running under WeChat 小游戏.
3	 *
4	 * Luna 启动期实际触达的 DOM 表面非常窄,只 mock 这几条:
5	 *   document.querySelectorAll("[data-src122]")   — 资源扫描 (微信下走 asset-inject 替代,这里返回空)
6	 *   document.getElementById(id)                   — 拿 canvas / preloader
7	 *   document.createElement(tag)                   — 创建 Image / video (微信走 wx.createImage)
8	 *   URL.createObjectURL(blob)                     — 配合 <img> <video> (微信下用 wxfile://)
9	 *   addEventListener / dispatchEvent              — DOMContentLoaded / bridge:ready / luna:starting
10	 *   navigator.userAgent / .languages              — Luna 探测 locale
11	 *
12	 * 微信全局: GameGlobal === wx 主线程的 globalThis. canvas 由 wx 创建并挂载.
13	 * 与 cocos-wx 不同, 我们不引入完整 web-adapter.js, 因为 Luna 表面更小.
14	 */
15	
16	(function bootShim() {
17	  const g = GameGlobal;
18	  if (!g.canvas) g.canvas = wx.createCanvas();
19	
20	  // wx.createCanvas() 默认 2x2 — PlayCanvas/Luna 看到无效尺寸不启动渲染循环。
21	  // 显式设为屏幕尺寸 * pixelRatio (高 DPI 能覆盖纹理); CSS 像素仍由 clientWidth/Height 报告。
22	  // 注: 若试玩广告需要响应屏幕旋转, 后续要监听 wx.onWindowResize 重设, 现在一次性够用。
23	  try {
24	    const sys = wx.getSystemInfoSync();
25	    const dpr = sys.pixelRatio || 1;
26	    const w = sys.windowWidth  || sys.screenWidth  || 750;
27	    const h = sys.windowHeight || sys.screenHeight || 1334;
28	    g.canvas.width  = Math.floor(w * dpr);
29	    g.canvas.height = Math.floor(h * dpr);
30	    g._screen = { cssWidth: w, cssHeight: h, dpr };
31	    // PlayCanvas / Luna 读 window.devicePixelRatio 决定 backbuffer 比例; window.inner{W,H} 读 CSS 尺寸。
32	    if (g.devicePixelRatio == null) g.devicePixelRatio = dpr;
33	    if (g.innerWidth  == null) g.innerWidth  = w;
34	    if (g.innerHeight == null) g.innerHeight = h;
35	    if (g.outerWidth  == null) g.outerWidth  = w;
36	    if (g.outerHeight == null) g.outerHeight = h;
37	    g.screen = g.screen || { width: w, height: h, availWidth: w, availHeight: h };
38	    console.log('[bootShim] canvas sized to', g.canvas.width + 'x' + g.canvas.height, 'css=', w + 'x' + h, 'dpr=', dpr);
39	  } catch (e) {
40	    console.warn('[bootShim] canvas size fail:', e && e.message);
41	    g.canvas.width  = 750;
42	    g.canvas.height = 1334;
43	  }
44	
45	  // canvas: 试玩 runtime 上 wx.createCanvas() 返回的对象**已带** addEventListener，但那是 playable-libs
46	  // 拦截过的有 bug 版本（内部 fi(...).addEventListener 抛 TypeError）。**总是**挂 _bus，下游优先用 _bus。
47	  {
48	    const __canvasBus = (function () {
49	      const map = new Map();
50	      return {
51	        on(t, cb) { (map.get(t) || map.set(t, new Set()).get(t)).add(cb); },
52	        off(t, cb) { const s = map.get(t); if (s) s.delete(cb); },
53	        emit(t, ev) { const s = map.get(t); if (s) for (const cb of s) try { cb(ev); } catch (e) { console.error(e); } },
54	        // 探针: 列出已注册的事件类型 + 每类的回调数, 看 PC 真在监听啥
55	        _stats() {
56	          const out = {};
57	          for (const [k, s] of map.entries()) out[k] = s.size;
58	          return out;
59	        },
60	        _types() { return Array.from(map.keys()); },
61	        _count(t) { const s = map.get(t); return s ? s.size : 0; },
62	        _listSources(t) {
63	          const s = map.get(t);
64	          if (!s) return [];
65	          const out = [];
66	          for (const cb of s) {
67	            try { out.push(String(cb).slice(0, 300)); } catch (e) { out.push('<toString fail>'); }
68	          }
69	          return out;
70	        },
71	      };
72	    })();
73	    g.canvas._bus = __canvasBus;
74	    // 覆盖 canvas.addEventListener / removeEventListener / dispatchEvent → 走 _bus。
75	    // 之前以为"原版有功能,留着"，错的：playable-libs 的 wrap 内部 fi(...).addEventListener 永远抛 TypeError，
76	    // PlayCanvas init 调到（webglcontextlost / mousemove 等）就炸。改用 _bus 后所有注册都安全落地。
77	    g.canvas.addEventListener = function (t, cb) { __canvasBus.on(t, cb); };
78	    g.canvas.removeEventListener = function (t, cb) { __canvasBus.off(t, cb); };
79	    g.canvas.dispatchEvent = function (ev) { __canvasBus.emit(ev && ev.type, ev); return true; };
80	    // PlayCanvas 用 canvas.getBoundingClientRect() 取视口；wx canvas 没这方法，补一个，
81	    // 用 canvas.width/height 当 viewport（试玩广告画布即全屏）。
82	    if (typeof g.canvas.getBoundingClientRect !== 'function') {
83	      g.canvas.getBoundingClientRect = function () {
84	        // 返回 CSS 像素尺寸 (PlayCanvas 用此值 * devicePixelRatio 算 backbuffer 大小)
85	        const w = (g._screen && g._screen.cssWidth)  || this.width  || 0;
86	        const h = (g._screen && g._screen.cssHeight) || this.height || 0;
87	        return { x: 0, y: 0, left: 0, top: 0, right: w, bottom: h, width: w, height: h };
88	      };
89	    }
90	    // PlayCanvas 用 clientWidth/Height 配合 devicePixelRatio 算 backbuffer 像素 — 必须返回 CSS 尺寸,
91	    // 否则会出现 backbuffer = canvas.width * dpr → 每帧翻倍直到爆显存。
92	    const dims = ['clientWidth', 'clientHeight', 'offsetWidth', 'offsetHeight'];
93	    for (const k of dims) {
94	      if (g.canvas[k] == null) {
95	        Object.defineProperty(g.canvas, k, {
96	          configurable: true,
97	          get() {
98	            const w = (g._screen && g._screen.cssWidth)  || this.width  || 0;
99	            const h = (g._screen && g._screen.cssHeight) || this.height || 0;
100	            return k.includes('Width') ? w : h;
101	          },
102	        });
103	      }
104	    }
105	    // 不直接覆盖 canvas.addEventListener — 留给 playable-libs 那条路径继续；下游用 _bus 安全注册。
106	
107	    // ---------- 触控桥接 wx.onTouch* → canvas._bus → PC TouchDevice ----------
108	    // PlayCanvas TouchDevice 在 init 时 canvas.addEventListener('touchstart'/'move'/'end'/'cancel', ...).
109	    // 我们的 canvas.addEventListener 已重定向到 __canvasBus.on; 这里把 wx.onTouchStart 等 fan-out
110	    // 进 bus, 构造与 DOM TouchEvent 兼容的 evt: e.touches / changedTouches / targetTouches + preventDefault.
111	    // wx 触点坐标 clientX/Y 已是 CSS 像素 (与 canvas.getBoundingClientRect 一致); PC 内部会自行 * dpr.
112	    function makeTouchObj(t) {
113	      // Touch 对象需要的字段: identifier, clientX/Y, pageX/Y, screenX/Y, target, force, radiusX/Y
114	      const x = t.clientX, y = t.clientY;
115	      return {
116	        identifier: t.identifier,
117	        clientX: x, clientY: y,
118	        pageX: x, pageY: y,
119	        screenX: x, screenY: y,
120	        radiusX: 1, radiusY: 1, force: t.force == null ? 1 : t.force, rotationAngle: 0,
121	        target: g.canvas,
122	      };
123	    }
124	    // Luna PC fork 的实际游戏输入挂在 window 的 mousedown/mousemove/mouseup (不是 touchstart/move)。
125	    // 触屏要同时合成 mouse 事件; touchstart→mousedown, touchmove→mousemove, touchend→mouseup。
126	    const TOUCH_TO_MOUSE = { touchstart: 'mousedown', touchmove: 'mousemove', touchend: 'mouseup', touchcancel: 'mouseup' };
127	    let __touchDispatchCnt = 0;
128	    let __lastTouchPos = { x: 0, y: 0 };
129	    function makeMouseEv(type, x, y) {
130	      return {
131	        type,
132	        clientX: x, clientY: y, pageX: x, pageY: y, screenX: x, screenY: y,
133	        offsetX: x, offsetY: y, x: x, y: y,
134	        button: 0, buttons: type === 'mouseup' ? 0 : 1, which: 1, detail: 1,
135	        movementX: 0, movementY: 0,
136	        ctrlKey: false, shiftKey: false, altKey: false, metaKey: false,
137	        target: g.canvas, currentTarget: g.canvas,
138	        timeStamp: Date.now(),
139	        preventDefault() {}, stopPropagation() {}, stopImmediatePropagation() {},
140	        isTrusted: true, bubbles: true, cancelable: true,
141	      };
142	    }
143	    function dispatchTouch(type, res) {
144	      const list = (res.touches || []).map(makeTouchObj);
145	      const changed = (res.changedTouches || res.touches || []).map(makeTouchObj);
146	      const ev = {
147	        type,
148	        touches: list,
149	        changedTouches: changed,
150	        targetTouches: list,
151	        timeStamp: res.timeStamp || Date.now(),
152	        target: g.canvas,
153	        currentTarget: g.canvas,
154	        preventDefault() {}, stopPropagation() {}, stopImmediatePropagation() {},
155	        isTrusted: true, bubbles: true, cancelable: true,
156	      };
157	      // 取触点坐标 (touchend 用最后已知坐标, 因为 changedTouches[0] 才有点)
158	      const pt = list[0] || changed[0];
159	      const px = pt ? pt.clientX : __lastTouchPos.x;
160	      const py = pt ? pt.clientY : __lastTouchPos.y;
161	      if (pt) __lastTouchPos = { x: px, y: py };
162	
163	      const __isLogTouch = __touchDispatchCnt < 5;
164	      if (__isLogTouch) {
165	        __touchDispatchCnt++;
166	        console.warn('[touch#' + __touchDispatchCnt + '] type=' + type +
167	                     ' touches=' + list.length + ' x=' + px + ' y=' + py);
168	        // PC 内部状态 before-emit
169	        try {
170	          const _pc = g.pc;
171	          const _app = (_pc && _pc.Application && _pc.Application.getApplication && _pc.Application.getApplication()) || g.app;
172	          if (_app) {
173	            const m = _app.mouse, t = _app.touch;
174	            console.warn('[touch#' + __touchDispatchCnt + '] BEFORE app.mouse=' + (m ? ('en=' + m._enabled + ' tgt=' + (m._target && m._target.constructor && m._target.constructor.name) + ' btns=' + JSON.stringify(m._buttons || [])) : 'NULL') +
175	                         ' app.touch=' + (t ? ('en=' + t._enabled + ' el=' + (t._element && t._element.constructor && t._element.constructor.name) + ' tn=' + (t._touches ? t._touches.length : 'undef')) : 'NULL'));
176	          } else {
177	            console.warn('[touch#' + __touchDispatchCnt + '] no app');
178	          }
179	        } catch (e) { console.warn('[touch#] before-probe threw:', e && e.message); }
180	      }
181	      // 1) 派发 touch 事件 (canvas / body / docEl / doc / window)
182	      __canvasBus.emit(type, ev);
183	      const doc = g.document;
184	      if (doc) {
185	        if (doc.body && doc.body._bus) doc.body._bus.emit(type, ev);
186	        if (doc.documentElement && doc.documentElement._bus) doc.documentElement._bus.emit(type, ev);
187	        if (doc._bus) doc._bus.emit(type, ev);
188	      }
189	      if (g._winBus) g._winBus.emit(type, ev);
190	
191	      // 2) 同步合成 mouse 事件 — Luna PC 实际走这条
192	      const mouseType = TOUCH_TO_MOUSE[type];
193	      if (mouseType) {
194	        const mev = makeMouseEv(mouseType, px, py);
195	        if (g._winBus) g._winBus.emit(mouseType, mev);
196	        __canvasBus.emit(mouseType, mev);
197	        if (doc && doc.body && doc.body._bus) doc.body._bus.emit(mouseType, mev);
198	        if (doc && doc.documentElement && doc.documentElement._bus) doc.documentElement._bus.emit(mouseType, mev);
199	        if (doc && doc._bus) doc._bus.emit(mouseType, mev);
200	      }
201	      // 3) 合成 pointer 事件 (现代游戏多用 PointerEvent, w3c 标准要求 pointerdown 先于 mousedown)
202	      const POINTER_MAP = { touchstart: 'pointerdown', touchmove: 'pointermove', touchend: 'pointerup', touchcancel: 'pointercancel' };
203	      const ptype = POINTER_MAP[type];
204	      if (ptype) {
205	        const pev = Object.assign(makeMouseEv(ptype, px, py), {
206	          pointerId: (pt && pt.identifier) || 1, pointerType: 'touch', isPrimary: true,
207	          width: 1, height: 1, pressure: 0.5, tangentialPressure: 0, tiltX: 0, tiltY: 0, twist: 0,
208	        });
209	        if (g._winBus) g._winBus.emit(ptype, pev);
210	        __canvasBus.emit(ptype, pev);
211	        if (doc && doc.body && doc.body._bus) doc.body._bus.emit(ptype, pev);
212	        if (doc && doc.documentElement && doc.documentElement._bus) doc.documentElement._bus.emit(ptype, pev);
213	      }
214	      // 4.5) 直接写 UnityEngine.Input 内部状态 — 既然 PC mouse._buttons 更新了但 UI.GetMouseButton(0) 返回 false,
215	      //     说明 Luna Input 不读 pc.app.mouse。从 UI 字段布局看: X$=touches array, W$=mousePosition Vector,
216	      //     z$/A$/B$ 是 mouseButtons/mouseButtonsDown/mouseButtonsUp 三个长度3的数组。
217	      //     直接写, 让 game UnityEngine.Input.touchCount/GetMouseButton/touches 即时拿到结果。
218	      try {
219	        const UI = g.UnityEngine && g.UnityEngine.Input;
220	        if (UI) {
221	          const isDown   = (type === 'touchstart');
222	          const isUp     = (type === 'touchend' || type === 'touchcancel');
223	          const isActive = (type !== 'touchend' && type !== 'touchcancel');
224	          const scrH = (g._screen && g._screen.cssHeight) || (g.canvas && g.canvas.height) || 1334;
225	          // Unity 坐标系 Y 朝上, DOM Y 朝下 — 翻转
226	          const ux = px;
227	          const uy = scrH - py;
228	          // mousePosition (W$ 形如 {x,y,_data})
229	          if (UI.W$ && typeof UI.W$ === 'object') {
230	            UI.W$.x = ux; UI.W$.y = uy;
231	            if (UI.W$._data && UI.W$._data.length >= 2) { UI.W$._data[0] = ux; UI.W$._data[1] = uy; }
232	          }
233	          // 备用 — 有些 mouse pos 字段命名为 J$ (相同结构)
234	          if (UI.J$ && typeof UI.J$ === 'object' && UI.J$.x !== undefined) {
235	            UI.J$.x = ux; UI.J$.y = uy;
236	            if (UI.J$._data && UI.J$._data.length >= 2) { UI.J$._data[0] = ux; UI.J$._data[1] = uy; }
237	          }
238	          // mouseButtons[0] (left)
239	          if (Array.isArray(UI.z$) && UI.z$.length >= 1) UI.z$[0] = isActive;
240	          if (Array.isArray(UI.A$) && UI.A$.length >= 1) UI.A$[0] = isDown;
241	          if (Array.isArray(UI.B$) && UI.B$.length >= 1) UI.B$[0] = isUp;
242	          // touches array — 用 Bridge.NET Touch 类如果有, 否则 plain object 兜底
243	          let mockT = null;
244	          if (isActive) {
245	            const TC = g.UnityEngine && g.UnityEngine.Touch;
246	            if (TC && typeof TC.ctor === 'function') {
247	              try { mockT = new TC.ctor(); } catch (e) {}
248	            }
249	            if (!mockT && TC && TC.$$initCtor) {
250	              try { mockT = TC.$$initCtor(); } catch (e) {}
251	            }
252	            if (!mockT) {
253	              mockT = {
254	                fingerId: (pt && pt.identifier) || 0,
255	                position: { x: ux, y: uy, _data: [ux, uy] },
256	                rawPosition: { x: ux, y: uy, _data: [ux, uy] },
257	                deltaPosition: { x: 0, y: 0, _data: [0, 0] },
258	                deltaTime: 0.016, tapCount: 1, pressure: 1, maximumPossiblePressure: 1,
259	                radius: 1, radiusVariance: 0, altitudeAngle: 0, azimuthAngle: 0,
260	                phase: type === 'touchstart' ? 0 : (type === 'touchmove' ? 1 : 3),
261	                type: 0,  // Touch.Direct
262	              };
263	            } else {
264	              // 填充 Bridge.NET 实例字段
265	              mockT.fingerId = (pt && pt.identifier) || 0;
266	              if (mockT.position) { mockT.position.x = ux; mockT.position.y = uy; }
267	              else mockT.position = { x: ux, y: uy };
268	              mockT.phase = type === 'touchstart' ? 0 : (type === 'touchmove' ? 1 : 3);
269	              mockT.pressure = 1;
270	            }
271	          }
272	          if (isActive) {
273	            UI.touches = [mockT];
274	            UI.X$ = [mockT];
275	            if (typeof UI.V$ === 'number' || UI.V$ === 0) UI.V$ = 1;  // touchCount maybe
276	            if (typeof UI.G$ === 'number' || UI.G$ === 0) UI.G$ = 1;
277	          } else {
278	            UI.touches = [];
279	            UI.X$ = [];
280	            UI.V$ = 0; UI.G$ = 0;
281	          }
282	          if (__isLogTouch) {
283	            console.warn('[touch#' + __touchDispatchCnt + '] UI inj: touchCount=' + UI.touchCount +
284	                         ' GetMouseButton(0)=' + (typeof UI.GetMouseButton === 'function' ? UI.GetMouseButton(0) : 'N/A') +
285	                         ' z$=' + JSON.stringify(Array.from(UI.z$ || [])) +
286	                         ' W$={x:' + (UI.W$ && UI.W$.x) + ',y:' + (UI.W$ && UI.W$.y) + '}');
287	          }
288	        }
289	      } catch (e) { console.warn('[UE inject] threw:', e && e.message); }
290	
291	      // 4) touchend 后合成 click — body._bus.click 有监听器, 多半是 CTA/UI 按钮
292	      if (type === 'touchend') {
293	        const cev = makeMouseEv('click', px, py);
294	        if (g._winBus) g._winBus.emit('click', cev);
295	        __canvasBus.emit('click', cev);
296	        if (doc && doc.body && doc.body._bus) doc.body._bus.emit('click', cev);
297	      }
298	      // 派完之后再读一次 — 看 PC Mouse._buttons / TouchDevice._touches 是否被更新
299	      if (__isLogTouch) {
300	        try {
301	          const _pc = g.pc;
302	          const _app = (_pc && _pc.Application && _pc.Application.getApplication && _pc.Application.getApplication()) || g.app;
303	          if (_app) {
304	            const m = _app.mouse, t = _app.touch;
305	            console.warn('[touch#' + __touchDispatchCnt + '] AFTER  app.mouse btns=' + (m ? JSON.stringify(m._buttons || []) : 'NULL') +
306	                         ' app.touch tn=' + (t && t._touches ? t._touches.length : (t ? 'no-_touches:keys=' + Object.keys(t).slice(0,8).join(',') : 'NULL')));
307	          }
308	        } catch (e) { console.warn('[touch#] after-probe threw:', e && e.message); }
309	        // UnityEngine.Input snapshot diff: 哪个 mangled 字段被改了 = touches/mouseButtons 真位置
310	        try {
311	          if (g.__UI_snapshotFn && g.__UI_snapshot_initial) {
312	            const after = g.__UI_snapshotFn();
313	            const before = g.__UI_snapshot_initial;
314	            const diffs = [];
315	            for (const k of Object.keys(after)) {
316	              if (before[k] !== after[k]) diffs.push(k + ':[' + before[k] + ']→[' + after[k] + ']');
317	            }
318	            console.warn('[touch#' + __touchDispatchCnt + '] UI diff: ' + (diffs.length ? diffs.slice(0,12).join(' || ') : 'NO_CHANGE'));
319	          }
320	        } catch (e) { console.warn('[touch#] UI-diff threw:', e && e.message); }
321	      }
322	      // 第 1 次真触摸后, 重新 dump bus 状态: 如果 win._bus.mousedown 从 x2 → x1, 说明 PC SoundManager
323	      // unlock handler 自删了 → 我们 emit 的 mouse 事件确实跑到了真 PC handler
324	      if (__touchDispatchCnt === 1 && g.__busesForRedump) {
325	        setTimeout(function () {
326	          try {
327	            const B = g.__busesForRedump || {};
328	            const c = function (b, t) { return b && b._count ? b._count(t) : 'N/A'; };
329	            console.warn('[postTouch] win._bus mousedown=' + c(B.win, 'mousedown') +
330	                         ' mousemove=' + c(B.win, 'mousemove') +
331	                         ' mouseup=' + c(B.win, 'mouseup') +
332	                         ' click=' + c(B.win, 'click') +
333	                         ' pointerdown=' + c(B.win, 'pointerdown'));
334	            console.warn('[postTouch] body._bus touchstart=' + c(B.body, 'touchstart') +
335	                         ' click=' + c(B.body, 'click') +
336	                         ' pointerdown=' + c(B.body, 'pointerdown'));
337	            console.warn('[postTouch] canvas._bus touchstart=' + c(B.canvas, 'touchstart') +
338	                         ' mousedown=' + c(B.canvas, 'mousedown') +
339	                         ' pointerdown=' + c(B.canvas, 'pointerdown'));
340	            // 把目标 listener 源码再 dump 一次, 看哪些 type 多了
341	            if (B.body && B.body._listSources) {
342	              console.warn('[postTouch] body._bus pointerdown sources: ' + JSON.stringify((B.body._listSources('pointerdown')||[]).map(s => s.replace(/\s+/g,' '))));
343	            }
344	          } catch (e) { console.warn('[postTouch] dump threw:', e && e.message); }
345	        }, 50);
346	      }
347	    }
348	    let __touchBound = { start: false, move: false, end: false, cancel: false };
349	    if (typeof wx !== 'undefined') {
350	      try { if (typeof wx.onTouchStart  === 'function') { wx.onTouchStart (r => dispatchTouch('touchstart',  r)); __touchBound.start  = true; } } catch (e) { console.warn('[bootShim] onTouchStart  bind fail:', e && e.message); }
351	      try { if (typeof wx.onTouchMove   === 'function') { wx.onTouchMove  (r => dispatchTouch('touchmove',   r)); __touchBound.move   = true; } } catch (e) { console.warn('[bootShim] onTouchMove   bind fail:', e && e.message); }
352	      try { if (typeof wx.onTouchEnd    === 'function') { wx.onTouchEnd   (r => dispatchTouch('touchend',    r)); __touchBound.end    = true; } } catch (e) { console.warn('[bootShim] onTouchEnd    bind fail:', e && e.message); }
353	      try { if (typeof wx.onTouchCancel === 'function') { wx.onTouchCancel(r => dispatchTouch('touchcancel', r)); __touchBound.cancel = true; } } catch (e) { console.warn('[bootShim] onTouchCancel bind fail:', e && e.message); }
354	      console.warn('[bootShim] wx touch handlers wired:', JSON.stringify(__touchBound));
355	    } else {
356	      console.warn('[bootShim] no wx, touch wiring skipped');
357	    }
358	  }
359	
360	  // ---------- window ----------
361	  if (!g.window) g.window = g;
362	  g.self = g.self || g;
363	
