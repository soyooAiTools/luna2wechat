457	      if (typeof g.WebAssembly[k] !== 'function') {
458	        g.WebAssembly[k] = function (msg) { const e = new Error(msg); e.name = 'WebAssembly.' + k; return e; };
459	      }
460	    }
461	
462	    // ---------- WebAssembly.instantiate → WXWebAssembly.instantiate(static .wasm.br) ----------
463	    // WeChat 试玩 runtime 的 WXWebAssembly.instantiate 只吃文件路径，不吃 buffer。
464	    // Luna 把 Box2D + Mecanim 两份 WASM 当 base64 data: URI 直接 atob 后 instantiate(buffer,...)。
465	    // build 时已经用 extract-wasm.cjs 把这两个模块解出来 → box2d.wasm.br / mecanim.wasm.br。
466	    // 这里按 byteLength 把调用改路成 WXWebAssembly.instantiate('<name>.wasm.br', imports)。
467	    // byteLength 以 extract-wasm.cjs 输出的 luna-wasm.json 为准；换 Luna 包时重跑脚本会更新两个文件，
468	    // 然后**回来更新这张 size→file 表**(脚本在末尾 console.error 打印 manifest)。
469	    // 路径加载 manifest（按 byteLength → 包内文件）。两份都用 .br 压缩省主包体积。
470	    const _wasmFiles = {
471	      168334: 'box2d.wasm.br',
472	      271539: 'mecanim.wasm.br',
473	    };
474	    // imports 处理模式：'pass'(默认，原样传) / 'clean'(包一层 thunk) / 'noop'(全 noop) / 'noop-arity'(按 arity noop)
475	    // 默认 pass：根因（monkey-patch 递归）已通过 unpatch 解决，emscripten 原 imports 直接可用。
476	    function cleanImports(imp) {
477	      const mode = (typeof globalThis !== 'undefined' && globalThis.__WASM_IMPORT_MODE) || 'pass';
478	      if (!imp || typeof imp !== 'object') return imp;
479	      const out = {};
480	      for (const m of Object.keys(imp)) {
481	        const mod = imp[m];
482	        if (!mod || typeof mod !== 'object') { out[m] = mod; continue; }
483	        const dst = {};
484	        for (const n of Object.keys(mod)) {
485	          const v = mod[n];
486	          if (typeof v !== 'function') { dst[n] = v; continue; }
487	          if (mode === 'pass') dst[n] = v;
488	          else if (mode === 'clean') dst[n] = function () { return v.apply(null, arguments); };
489	          else if (mode === 'noop') dst[n] = function () { return 0; };
490	          else if (mode === 'noop-arity') {
491	            // 用 v.length 模拟 arity（不一定准但有时候 trigger 不同 path）
492	            dst[n] = new Function(...Array(v.length).fill(0).map((_, i) => 'a' + i), 'return 0');
493	          }
494	          else dst[n] = v;
495	        }
496	        out[m] = dst;
497	      }
498	      return out;
499	    }
500	
501	    // 保存原始引用。WXWebAssembly bridge 内部会回调 WebAssembly.instantiate(path, ...)。
502	    // 解法：在 redirect 前临时把 WebAssembly.instantiate 还原为原函数，emscripten 一次成功后永久不再 patch。
503	    const _origInstantiate = g.WebAssembly.instantiate;
504	    const _ourShim = function (arg, imports) {
505	      console.log('[WASM-SHIM] called argType=' + (typeof arg) + (arg && arg.byteLength != null ? ' len=' + arg.byteLength : ''));
506	      // 字符串路径 — 走原 bridge
507	      if (typeof arg === 'string') {
508	        return _origInstantiate.apply(this, arguments);
509	      }
510	      let bytes = null;
511	      if (arg instanceof ArrayBuffer) bytes = new Uint8Array(arg);
512	      else if (arg && arg.buffer instanceof ArrayBuffer) bytes = new Uint8Array(arg.buffer, arg.byteOffset || 0, arg.byteLength);
513	      const len = bytes ? bytes.length : -1;
514	      const file = _wasmFiles[len];
515	      if (!file) {
516	        const head = bytes ? Array.from(bytes.slice(0, 16)).map(b => b.toString(16).padStart(2,'0')).join(' ') : '<no-bytes>';
517	        console.error('[WASM] unknown buffer len=' + len + ' head=' + head + ' — update _wasmFiles in dom-shim.js');
518	        return Promise.reject(new Error('unmapped WASM buffer length=' + len));
519	      }
520	      // 默认 'pass'：原样转发 emscripten 的 imports；unpatch 切断递归后已不需要 noop 替换。
521	      // 仍可通过 globalThis.__WASM_IMPORT_MODE 切到 clean/noop/noop-arity 调试。
522	      const mode = (typeof globalThis !== 'undefined' && globalThis.__WASM_IMPORT_MODE) || 'pass';
523	      if (imports && typeof imports === 'object') {
524	        const topo = Object.keys(imports).map(k => k + ':' + (typeof imports[k]) + '(' + (imports[k] && typeof imports[k] === 'object' ? Object.keys(imports[k]).length : '?') + ')').join(',');
525	        console.log('[WASM] imports top-level = {' + topo + '}');
526	      }
527	      const cleaned = cleanImports(imports);
528	      console.log('[WASM] redirect len=' + len + ' -> ' + file + ' mode=' + mode + ' defer=setTimeout+unpatch');
529	      // 关键：WXWebAssembly === WebAssembly (或 WXWebAssembly impl 在内部 resolves WebAssembly.instantiate at runtime)
530	      // 若我们 patch 仍 active, 内部会递归撞回 _ourShim 死循环。
531	      // 因此: setTimeout 切到全新栈, 还原 WebAssembly.instantiate 为原函数, 再调用. emscripten 成功后不再需要 patch.
532	      return new Promise((resolve, reject) => {
533	        setTimeout(() => {
534	          console.log('[WASM] unpatching WebAssembly.instantiate, calling original with path=' + file);
535	          g.WebAssembly.instantiate = _origInstantiate;  // 还原, 不再 patch
536	          try {
537	            _origInstantiate.call(g.WebAssembly, file, cleaned).then(
538	              v => { console.log('[WASM] OK exports first=' + Object.keys(v.instance.exports).slice(0,3).join(',')); resolve(v); },
539	              e => { console.error('[WASM] FAIL', e && e.message || e); reject(e); }
540	            );
541	          } catch (e) { console.error('[WASM] sync throw', e && e.message || e); reject(e); }
542	        }, 0);
543	      });
544	    };
545	    // 装上 patch
546	    g.WebAssembly.instantiate = _ourShim;
547	  }
