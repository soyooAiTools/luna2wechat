790	        if (inst == null) return false;
791	        if (ShimImpl && inst instanceof ShimImpl) return true;
792	        try { return !!duckCheck(inst); } catch (e) { return false; }
793	      },
794	      configurable: true,
795	    });
796	    return Ctor;
797	  }
798	  // wx.Image 鸭子型: 有 .src (string) + 有 .width/.height (number) + 不是 video/canvas/audio
799	  const isWxImageLike = (o) => {
800	    if (typeof o !== 'object') return false;
801	    if (typeof o.src !== 'string') return false;
802	    if (typeof o.width !== 'number' || typeof o.height !== 'number') return false;
803	    const tag = o.tagName;
804	    if (tag === 'VIDEO' || tag === 'AUDIO' || tag === 'CANVAS') return false;
805	    // wx 原生 Image: 看 constructor.name (probe 抓到是 'nr'), 或我们 asset-inject 注册的 wx.createImage 实例
806	    return true;
807	  };
808	  const isCanvasLike = (o) => {
809	    if (typeof o !== 'object' || o == null) return false;
810	    if (o.tagName === 'CANVAS') return true;
811	    return typeof o.getContext === 'function' && typeof o.width === 'number' && typeof o.height === 'number';
812	  };
813	  const isVideoLike = (o) => {
814	    if (typeof o !== 'object' || o == null) return false;
815	    return o.tagName === 'VIDEO';
816	  };
817	  if (typeof g.HTMLImageElement  === 'undefined') g.HTMLImageElement  = makeShimCtor(ImageShim,  isWxImageLike);
818	  if (typeof g.HTMLVideoElement  === 'undefined') g.HTMLVideoElement  = makeShimCtor(VideoShim,  isVideoLike);
819	  if (typeof g.HTMLAudioElement  === 'undefined') g.HTMLAudioElement  = AudioShim;
820	  if (typeof g.HTMLCanvasElement === 'undefined') g.HTMLCanvasElement = makeShimCtor(null,        isCanvasLike);
821	  if (typeof g.HTMLElement       === 'undefined') g.HTMLElement       = function HTMLElement() {};
822	  if (typeof g.Element           === 'undefined') g.Element           = function Element() {};
823	  if (typeof g.Node              === 'undefined') g.Node              = function Node() {};
824	
825	  // PlayCanvas SoundManager 期望 `new (window.AudioContext || window.webkitAudioContext)()`
826	  // 试玩 runtime 没 WebAudio API; 给个最小可用 stub, 让 SoundManager 能 new 出来不立即崩。
827	  // 真正播放走 wx.createInnerAudioContext (后面 sound 子系统再桥接)。
828	  function AudioContextShim() {
829	    this.state = 'running';
830	    this.sampleRate = 44100;
831	    this.currentTime = 0;
832	    this.destination = { connect() {}, disconnect() {} };
833	    this.listener = { setPosition() {}, setOrientation() {}, positionX: { value: 0 }, positionY: { value: 0 }, positionZ: { value: 0 } };
834	    this.createGain        = () => ({ gain: { value: 1, setValueAtTime() {} }, connect() {}, disconnect() {} });
835	    this.createBufferSource = () => ({ buffer: null, loop: false, playbackRate: { value: 1 }, connect() {}, disconnect() {}, start() {}, stop() {}, onended: null });
836	    this.createBuffer       = (ch, len, sr) => ({ numberOfChannels: ch, length: len, sampleRate: sr, duration: len / (sr || 1), getChannelData: () => new Float32Array(len) });
837	    this.createPanner       = () => ({ connect() {}, disconnect() {}, setPosition() {}, setOrientation() {} });
838	    this.createAnalyser     = () => ({ connect() {}, disconnect() {}, fftSize: 2048, getByteFrequencyData() {}, getByteTimeDomainData() {} });
839	    this.createOscillator   = () => ({ frequency: { value: 440 }, connect() {}, disconnect() {}, start() {}, stop() {} });
840	    this.decodeAudioData    = (buf, ok, fail) => { try { ok && ok({ duration: 0, sampleRate: 44100, numberOfChannels: 2, length: 0, getChannelData: () => new Float32Array(0) }); } catch (e) { fail && fail(e); } return Promise.resolve({ duration: 0, sampleRate: 44100, numberOfChannels: 2, length: 0, getChannelData: () => new Float32Array(0) }); };
841	    this.resume             = () => Promise.resolve();
842	    this.suspend            = () => Promise.resolve();
843	    this.close              = () => Promise.resolve();
844	    this.addEventListener   = () => {};
845	    this.removeEventListener= () => {};
846	  }
847	  if (typeof g.AudioContext       === 'undefined') g.AudioContext       = AudioContextShim;
848	  if (typeof g.webkitAudioContext === 'undefined') g.webkitAudioContext = AudioContextShim;
849	})();
