437	  // ---------- crypto (luna webpack 用 crypto.getRandomValues 做 uuidv4) ----------
438	  if (typeof g.crypto === 'undefined') {
439	    g.crypto = {
440	      getRandomValues(arr) {
441	        for (let i = 0; i < arr.length; i++) arr[i] = (Math.random() * 256) | 0;
442	        return arr;
443	      },
444	      randomUUID() {
445	        const b = new Uint8Array(16);
446	        for (let i = 0; i < 16; i++) b[i] = (Math.random() * 256) | 0;
447	        b[6] = (b[6] & 0x0f) | 0x40; b[8] = (b[8] & 0x3f) | 0x80;
448	        const h = [...b].map(x => x.toString(16).padStart(2, '0')).join('');
449	        return `${h.slice(0,8)}-${h.slice(8,12)}-${h.slice(12,16)}-${h.slice(16,20)}-${h.slice(20)}`;
450	      },
451	    };
452	  }
