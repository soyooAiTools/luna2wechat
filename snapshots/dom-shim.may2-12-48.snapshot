779	  // PlayCanvas Texture.setSource(t) 走:
780	  //   t instanceof HTMLImageElement || t instanceof HTMLCanvasElement
781	  //   || t instanceof HTMLVideoElement || t instanceof ArrayBuffer || (e = true);
782	  // e=true 时强制 _width=4 _height=4 _levels[0]=null → 黑/白 4x4 占位。
783	  // wx.createImage() 返的是 wx-native 对象 (constructor.name === 'nr'),
784	  // 跟 ImageShim 不同 prototype, instanceof 必失败 → 所有材质纹理失效 → 环境黑屏。
785	  // 修法: 用 Symbol.hasInstance 拦截 instanceof, 让 wx.Image / proxy 也通过。
786	  function makeShimCtor(ShimImpl, duckCheck) {
