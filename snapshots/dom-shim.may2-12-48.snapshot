767	    this.style = {};
768	    this.addEventListener = () => {};
769	    this.play = () => Promise.resolve();
770	    this.pause = () => {};
771	  }
772	  function AudioShim() {
773	    this.src = ''; this.volume = 1; this.loop = false; this.paused = true;
774	    this.addEventListener = () => {};
775	    this.play = () => Promise.resolve();
776	    this.pause = () => {};
777	  }
