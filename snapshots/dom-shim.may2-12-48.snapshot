376	      const map = new Map();
377	      const str = (typeof s === 'string') ? (s[0] === '?' ? s.slice(1) : s) : '';
378	      if (str) for (const part of str.split('&')) {
379	        if (!part) continue;
380	        const i = part.indexOf('=');
381	        const k = i < 0 ? decodeURIComponent(part) : decodeURIComponent(part.slice(0, i));
382	        const v = i < 0 ? '' : decodeURIComponent(part.slice(i + 1));
383	        map.set(k, v);
384	      }
385	      this.get = (k) => map.has(k) ? map.get(k) : null;
386	      this.has = (k) => map.has(k);
