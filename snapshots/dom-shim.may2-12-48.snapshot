585	      },
586	      querySelector(sel) {
587	        if (sel === '#application-canvas') return g.canvas;
588	        return null;
589	      },
590	      createElement(tag) {
591	        tag = String(tag).toLowerCase();
592	        if (tag === 'canvas') return wx.createCanvas();
