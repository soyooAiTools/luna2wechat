597	        if (tag === 'script') return makeNoop(tag);
598	        return makeNoop(tag);
599	      },
600	      addEventListener: (type, cb) => eventBus.on(type, cb),
601	      removeEventListener: (type, cb) => eventBus.off(type, cb),
602	      dispatchEvent: (ev) => eventBus.emit(ev.type, ev),
603	      _bus: eventBus,
604	      _registerElement(id, el) { elements.set(id, el); },
