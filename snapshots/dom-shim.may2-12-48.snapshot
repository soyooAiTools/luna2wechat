405	        if (k === 'assert') {
406	          console[k] = function (cond /*, ...msg */) { if (!cond) fallback.apply(null, ['[assert]'].concat(Array.prototype.slice.call(arguments, 1))); };
407	        } else {
408	          console[k] = fallback;
409	        }
410	      }
